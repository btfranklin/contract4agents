{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Contract4Agents Eval",
  "scopeName": "source.contract4agents.eval",
  "patterns": [
    {"include": "#comments"},
    {"include": "#strings"},
    {"include": "#eval-declaration"},
    {"include": "#given-values"},
    {"include": "#statements"},
    {"include": "#expressions"},
    {"include": "#types"},
    {"include": "#constants"},
    {"include": "#punctuation"},
    {"include": "#dotted-names"}
  ],
  "repository": {
    "comments": {
      "patterns": [
        {"name": "comment.line.number-sign.contract4agents-eval", "match": "#.*$"}
      ]
    },
    "strings": {
      "patterns": [
        {"name": "string.quoted.double.contract4agents-eval", "match": "\"(?:[^\"\\\\]|\\\\.)*\""}
      ]
    },
    "eval-declaration": {
      "patterns": [
        {
          "name": "meta.declaration.eval.contract4agents-eval",
          "match": "^\\s*(eval)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s+(for)\\s+([A-Za-z_][A-Za-z0-9_]*)(\\s*:)",
          "captures": {
            "1": {"name": "keyword.declaration.eval.contract4agents-eval"},
            "2": {"name": "entity.name.function.eval.contract4agents-eval"},
            "3": {"name": "keyword.control.relationship.contract4agents-eval"},
            "4": {"name": "entity.name.type.agent.contract4agents-eval"},
            "5": {"name": "punctuation.definition.block.contract4agents-eval"}
          }
        }
      ]
    },
    "given-values": {
      "patterns": [
        {
          "name": "meta.statement.given.fixture.contract4agents-eval",
          "match": "^\\s*(given)\\s+([A-Za-z_][A-Za-z0-9_]*)(\\s*=\\s*)([A-Z][A-Za-z0-9_]*)(\\.)(fixture)(\\()",
          "captures": {
            "1": {"name": "keyword.control.given.contract4agents-eval"},
            "2": {"name": "variable.other.assignment.contract4agents-eval"},
            "3": {"name": "keyword.operator.assignment.contract4agents-eval"},
            "4": {"name": "entity.name.type.contract4agents-eval"},
            "5": {"name": "punctuation.accessor.contract4agents-eval"},
            "6": {"name": "support.function.fixture.contract4agents-eval"},
            "7": {"name": "punctuation.section.group.begin.contract4agents-eval"}
          }
        },
        {
          "name": "meta.statement.given.scalar.contract4agents-eval",
          "match": "^\\s*(given)\\s+([A-Za-z_][A-Za-z0-9_]*)(\\s*=\\s*)(?!\\s*\")([^\"#\\n][^#\\n]*?)(?=\\s*(?:#|$))",
          "captures": {
            "1": {"name": "keyword.control.given.contract4agents-eval"},
            "2": {"name": "variable.other.assignment.contract4agents-eval"},
            "3": {"name": "keyword.operator.assignment.contract4agents-eval"},
            "4": {"name": "string.unquoted.scalar.contract4agents-eval"}
          }
        }
      ]
    },
    "statements": {
      "patterns": [
        {
          "name": "meta.statement.given.contract4agents-eval",
          "match": "^\\s*(given)\\s+([A-Za-z_][A-Za-z0-9_]*)(\\s*=\\s*)",
          "captures": {
            "1": {"name": "keyword.control.given.contract4agents-eval"},
            "2": {"name": "variable.other.assignment.contract4agents-eval"},
            "3": {"name": "keyword.operator.assignment.contract4agents-eval"}
          }
        },
        {"name": "keyword.control.expect.contract4agents-eval", "match": "^\\s*\\b(expect)\\b"}
      ]
    },
    "expressions": {
      "patterns": [
        {
          "name": "meta.function.trace.contract4agents-eval",
          "match": "\\b(trace)(\\.)(called|not_called|called_once|called_times|called_before|called_after|max_calls|not_tool_called_by|tool_called|agent_called|datasource_resolved|approval_requested|approval_granted|approval_denied|guardrail_rejected|contains)\\b",
          "captures": {
            "1": {"name": "support.variable.expression.contract4agents-eval"},
            "2": {"name": "punctuation.accessor.contract4agents-eval"},
            "3": {"name": "support.function.trace.contract4agents-eval"}
          }
        },
        {
          "name": "meta.reference.expression.contract4agents-eval",
          "match": "\\b(output|hidden_truth)(\\.)([A-Za-z_][A-Za-z0-9_.]*)\\b",
          "captures": {
            "1": {"name": "support.variable.expression.contract4agents-eval"},
            "2": {"name": "punctuation.accessor.contract4agents-eval"},
            "3": {"name": "variable.other.member.contract4agents-eval"}
          }
        },
        {"name": "support.function.expression.contract4agents-eval", "match": "\\b(semantic|quality)(?=\\s*\\()"},
        {"name": "keyword.control.expression.contract4agents-eval", "match": "\\bexpect\\b"},
        {"name": "keyword.operator.expression.contract4agents-eval", "match": "\\b(conforms|contains|excludes|discovers)\\b|==|!="},
        {"name": "support.variable.expression.contract4agents-eval", "match": "\\b(output|trace|hidden_truth)\\b"},
        {"name": "support.function.fixture.contract4agents-eval", "match": "\\bfixture(?=\\s*\\()"}
      ]
    },
    "types": {
      "patterns": [
        {"name": "storage.type.collection.contract4agents-eval", "match": "\\b(list|map)(?=\\s*\\[)"},
        {"name": "support.type.primitive.contract4agents-eval", "match": "\\b(string|integer|float|boolean|datetime)\\b"},
        {"name": "entity.name.type.contract4agents-eval", "match": "\\b[A-Z][A-Za-z0-9_]*\\b"},
        {"name": "storage.modifier.nullable.contract4agents-eval", "match": "\\?"}
      ]
    },
    "constants": {
      "patterns": [
        {"name": "constant.language.boolean.contract4agents-eval", "match": "\\b(true|false|null)\\b"},
        {"name": "constant.other.duration.contract4agents-eval", "match": "\\b[0-9]+(?:\\.[0-9]+)?(?:ms|s|m|h)\\b"},
        {"name": "constant.numeric.contract4agents-eval", "match": "\\b[0-9]+(?:\\.[0-9]+)?\\b"}
      ]
    },
    "punctuation": {
      "patterns": [
        {"name": "keyword.operator.arrow.contract4agents-eval", "match": "->"},
        {"name": "punctuation.section.group.contract4agents-eval", "match": "[()]"},
        {"name": "punctuation.section.sequence.contract4agents-eval", "match": "[\\[\\]]"},
        {"name": "punctuation.separator.sequence.contract4agents-eval", "match": ","},
        {"name": "punctuation.accessor.contract4agents-eval", "match": "\\."}
      ]
    },
    "dotted-names": {
      "patterns": [
        {"name": "support.function.dotted.contract4agents-eval", "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)+\\b"}
      ]
    }
  }
}
