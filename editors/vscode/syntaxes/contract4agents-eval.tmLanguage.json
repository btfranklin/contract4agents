{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Contract4Agents Eval",
  "scopeName": "source.contract4agents.eval",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#given-values"
    },
    {
      "include": "#eval-declaration"
    },
    {
      "include": "#statements"
    },
    {
      "include": "#expressions"
    },
    {
      "include": "#types"
    },
    {
      "include": "#dotted-names"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.contract4agents-eval",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.contract4agents-eval",
          "match": "\"(?:[^\"\\\\]|\\\\.)*\""
        }
      ]
    },
    "given-values": {
      "patterns": [
        {
          "name": "meta.statement.given.fixture.contract4agents-eval",
          "match": "^\\s*(given)\\s+([A-Za-z_][A-Za-z0-9_]*)(\\s*=\\s*)([A-Z][A-Za-z0-9_]*)(\\.)(fixture)(\\()",
          "captures": {
            "1": {
              "name": "keyword.control.given.contract4agents-eval"
            },
            "2": {
              "name": "variable.other.assignment.contract4agents-eval"
            },
            "3": {
              "name": "keyword.operator.assignment.contract4agents-eval"
            },
            "4": {
              "name": "entity.name.type.contract4agents-eval"
            },
            "5": {
              "name": "punctuation.accessor.contract4agents-eval"
            },
            "6": {
              "name": "support.function.fixture.contract4agents-eval"
            },
            "7": {
              "name": "punctuation.section.group.begin.contract4agents-eval"
            }
          }
        },
        {
          "name": "meta.statement.given.scalar.contract4agents-eval",
          "match": "^\\s*(given)\\s+([A-Za-z_][A-Za-z0-9_]*)(\\s*=\\s*)([^\"#\\n][^#\\n]*?)(?=\\s*(?:#|$))",
          "captures": {
            "1": {
              "name": "keyword.control.given.contract4agents-eval"
            },
            "2": {
              "name": "variable.other.assignment.contract4agents-eval"
            },
            "3": {
              "name": "keyword.operator.assignment.contract4agents-eval"
            },
            "4": {
              "name": "string.unquoted.scalar.contract4agents-eval"
            }
          }
        }
      ]
    },
    "eval-declaration": {
      "patterns": [
        {
          "name": "meta.declaration.eval.contract4agents-eval",
          "match": "^\\s*(eval)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s+(for)\\s+([A-Z][A-Za-z0-9_]*)\\s*(:)",
          "captures": {
            "1": {
              "name": "keyword.declaration.eval.contract4agents-eval"
            },
            "2": {
              "name": "entity.name.function.eval.contract4agents-eval"
            },
            "3": {
              "name": "keyword.control.contract4agents-eval"
            },
            "4": {
              "name": "entity.name.type.agent.contract4agents-eval"
            },
            "5": {
              "name": "punctuation.definition.block.contract4agents-eval"
            }
          }
        }
      ]
    },
    "statements": {
      "patterns": [
        {
          "name": "meta.statement.given.contract4agents-eval",
          "match": "^\\s*(given)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(=)",
          "captures": {
            "1": {
              "name": "keyword.control.given.contract4agents-eval"
            },
            "2": {
              "name": "variable.other.assignment.contract4agents-eval"
            },
            "3": {
              "name": "keyword.operator.assignment.contract4agents-eval"
            }
          }
        },
        {
          "name": "keyword.control.expect.contract4agents-eval",
          "match": "^\\s*\\b(expect)\\b"
        }
      ]
    },
    "expressions": {
      "patterns": [
        {
          "name": "keyword.control.expression.contract4agents-eval",
          "match": "\\b(expect|quality)\\b"
        },
        {
          "name": "meta.function.trace.contract4agents-eval",
          "match": "\\b(trace)(\\.)(called|not_called|called_once|called_times|called_before|called_after|max_calls|not_tool_called_by|tool_called|agent_called|datasource_resolved|approval_requested|approval_granted|approval_denied|contains)\\b",
          "captures": {
            "1": {
              "name": "support.variable.expression.contract4agents-eval"
            },
            "2": {
              "name": "punctuation.accessor.contract4agents-eval"
            },
            "3": {
              "name": "support.function.trace.contract4agents-eval"
            }
          }
        },
        {
          "name": "meta.reference.expression.contract4agents-eval",
          "match": "\\b(output|value|hidden_truth)(\\.)([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "support.variable.expression.contract4agents-eval"
            },
            "2": {
              "name": "punctuation.accessor.contract4agents-eval"
            },
            "3": {
              "name": "variable.other.member.contract4agents-eval"
            }
          }
        },
        {
          "name": "support.variable.expression.contract4agents-eval",
          "match": "\\b(output|trace|value|hidden_truth)\\b"
        },
        {
          "name": "keyword.operator.expression.contract4agents-eval",
          "match": "\\b(conforms|contains|excludes|discovers|subset_of|contains_all|equals_set|intersects|disjoint_from)\\b|==|!="
        },
        {
          "name": "constant.language.boolean.contract4agents-eval",
          "match": "\\b(true|false|null)\\b"
        },
        {
          "name": "constant.numeric.integer.contract4agents-eval",
          "match": "\\b[0-9]+\\b"
        },
        {
          "name": "punctuation.accessor.contract4agents-eval",
          "match": "\\."
        },
        {
          "name": "support.function.fixture.contract4agents-eval",
          "match": "\\bfixture\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.contract4agents-eval",
          "match": "\\b(string|integer|float|boolean|datetime|list|map)\\b"
        },
        {
          "name": "entity.name.type.contract4agents-eval",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "dotted-names": {
      "patterns": [
        {
          "name": "support.function.dotted.contract4agents-eval",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?:\\.[A-Za-z_][A-Za-z0-9_]*)+\\b"
        }
      ]
    }
  }
}
