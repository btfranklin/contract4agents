{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Contract4Agents",
  "scopeName": "source.contract4agents",
  "patterns": [
    {"include": "#comments"},
    {"include": "#strings"},
    {"include": "#declarations"},
    {"include": "#relationships"},
    {"include": "#assignments"},
    {"include": "#expressions"},
    {"include": "#types"},
    {"include": "#constants"}
  ],
  "repository": {
    "comments": {
      "patterns": [{"name": "comment.line.number-sign.contract4agents", "match": "#.*$"}]
    },
    "strings": {
      "patterns": [{"name": "string.quoted.double.contract4agents", "match": "\"(?:[^\"\\\\]|\\\\.)*\""}]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.declaration.contract4agents",
          "match": "^\\s*(type|tool|datasource|external_context|agent|composition|isolation|control|quality|operational_control|eval|run_spec)\\s+([A-Za-z_][A-Za-z0-9_.]*)(?:\\s+(for|from|to)\\s+([A-Za-z_][A-Za-z0-9_]*))?",
          "captures": {
            "1": {"name": "keyword.declaration.contract4agents"},
            "2": {"name": "entity.name.type.contract4agents"},
            "3": {"name": "keyword.control.relationship.contract4agents"},
            "4": {"name": "entity.name.type.agent.contract4agents"}
          }
        }
      ]
    },
    "relationships": {
      "patterns": [
        {
          "name": "meta.relationship.use.contract4agents",
          "match": "^\\s*(use)\\s+([A-Za-z_][A-Za-z0-9_.]*)(\\s*:)",
          "captures": {
            "1": {"name": "keyword.control.use.contract4agents"},
            "2": {"name": "support.function.capability.contract4agents"},
            "3": {"name": "punctuation.definition.block.contract4agents"}
          }
        },
        {
          "name": "meta.relationship.context.contract4agents",
          "match": "^\\s*(context)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(:)\\s*([^\\s]+)\\s+(from)\\s+(invocation|parent|handoff|stage|datasource|external)(?:\\s+([A-Za-z_][A-Za-z0-9_.]*))?",
          "captures": {
            "1": {"name": "keyword.control.context.contract4agents"},
            "2": {"name": "variable.other.context.contract4agents"},
            "4": {"name": "entity.name.type.contract4agents"},
            "5": {"name": "keyword.control.relationship.contract4agents"},
            "6": {"name": "constant.language.origin.contract4agents"},
            "7": {"name": "support.function.capability.contract4agents"}
          }
        },
        {
          "name": "meta.relationship.map.contract4agents",
          "match": "^\\s*(map)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(=)\\s*(input|context)(\\.)([A-Za-z_][A-Za-z0-9_.]*)",
          "captures": {
            "1": {"name": "keyword.control.map.contract4agents"},
            "2": {"name": "variable.parameter.mapping.contract4agents"},
            "3": {"name": "keyword.operator.assignment.contract4agents"},
            "4": {"name": "support.variable.mapping.contract4agents"},
            "5": {"name": "punctuation.accessor.contract4agents"},
            "6": {"name": "variable.other.mapping.contract4agents"}
          }
        }
      ]
    },
    "assignments": {
      "patterns": [
        {
          "name": "meta.assignment.contract4agents",
          "match": "^\\s*([A-Za-z_][A-Za-z0-9_]*)(\\s*=\\s*)",
          "captures": {
            "1": {"name": "variable.other.assignment.contract4agents"},
            "2": {"name": "keyword.operator.assignment.contract4agents"}
          }
        }
      ]
    },
    "expressions": {
      "patterns": [
        {
          "name": "meta.function.trace.contract4agents",
          "match": "\\b(trace)(\\.)(called|not_called|called_once|called_times|called_before|called_after|max_calls|not_tool_called_by|tool_called|agent_called|datasource_resolved|approval_requested|approval_granted|approval_denied|contains)\\b",
          "captures": {
            "1": {"name": "support.variable.expression.contract4agents"},
            "2": {"name": "punctuation.accessor.contract4agents"},
            "3": {"name": "support.function.trace.contract4agents"}
          }
        },
        {"name": "keyword.control.expression.contract4agents", "match": "\\b(expect|require|when|quality)\\b"},
        {"name": "keyword.operator.expression.contract4agents", "match": "\\b(conforms|contains|excludes|discovers|subset_of|contains_all|equals_set|intersects|disjoint_from)\\b|==|!="}
      ]
    },
    "types": {
      "patterns": [
        {"name": "support.type.primitive.contract4agents", "match": "\\b(string|integer|float|boolean|datetime|list|map)\\b"},
        {"name": "entity.name.type.contract4agents", "match": "\\b[A-Z][A-Za-z0-9_]*\\b"}
      ]
    },
    "constants": {
      "patterns": [
        {"name": "constant.language.boolean.contract4agents", "match": "\\b(true|false|null)\\b"},
        {"name": "constant.language.enum.contract4agents", "match": "\\b(enabled|denied|preapproved|approval_required|host|provider_hosted|remote|delegate|handoff|model|adapter|host_attested|post_run|semantic|advisory|reviewer|evaluator)\\b"},
        {"name": "constant.numeric.contract4agents", "match": "\\b[0-9]+(?:\\.[0-9]+)?\\b"}
      ]
    }
  }
}
