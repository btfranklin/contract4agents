{
  "agents": {
    "HostDriftAgent": {
      "factory": "tests.fixtures.host_drift_app:build_agent_factory",
      "name": "HostDriftAgent"
    }
  },
  "host_context": {
    "HostDriftAgent": [
      "HostSummary"
    ]
  },
  "hosted_tools": {
    "openai.web_search": {
      "config": {
