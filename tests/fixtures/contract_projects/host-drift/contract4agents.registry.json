      "python": "tests.fixtures.host_drift_app:DriftResultModel"
    }
  },
  "prompts": {
    "HostDriftAgent": {
      "path": "prompts/HostDriftAgent.md"
    }
  },
  "tools": {
    "drift.lookup": {
      "permissions": {
        "HostDriftAgent": "preapproved"
      },
      "python": "tests.fixtures.host_drift_app:lookup"
    }
  },
  "version": 2
