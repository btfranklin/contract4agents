agent HostDriftAgent(request: DriftRequest) -> DriftResult:
    description = "Coordinates host-code drift fixture checks."
    goal = "Return a compact host drift result."
    use tool drift.lookup from tools.drift preapproved
    use hosted_tool openai.web_search context_size "medium"
    host_context = [HostSummary]
    success = [
        "Summary is grounded in host registry inputs.",
        "Score is present.",
    ]
