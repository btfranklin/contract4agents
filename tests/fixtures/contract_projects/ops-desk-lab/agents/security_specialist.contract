agent SecuritySpecialist(
    request: StartRequest,
    account: CustomerAccount,
    intent: RequestIntent
) -> OpsDeskResult:

    use tool security.audit_log from tools.security preapproved
    use tool security.lock_account from tools.security requires approval

    goal = "Investigate suspicious account activity and lock accounts only with approval."

    policy = [
        "inspect audit evidence before naming a security risk",
        "request approval before account lock actions",
    ]

    guards = [
        require(output conforms OpsDeskResult),
        forbid(tool.security.lock_account unless approved_by_human),
    ]
