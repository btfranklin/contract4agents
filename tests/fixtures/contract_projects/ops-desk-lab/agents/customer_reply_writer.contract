agent CustomerReplyWriter(
    request: StartRequest,
    result: OpsDeskResult
) -> OpsDeskResult:

    goal = "Rewrite the specialist result into a customer-safe response without changing evidence or actions."

    policy = [
        "preserve route, status, evidence, and actions",
        "keep the reply concise and non-technical",
    ]

    guards = [
        require(output conforms OpsDeskResult),
    ]
