agent AccessSpecialist(
    request: StartRequest,
    account: CustomerAccount,
    intent: RequestIntent
) -> OpsDeskResult:

    use tool access.list_permissions from tools.access preapproved
    use tool access.grant_access from tools.access requires approval

    goal = "Resolve access and entitlement requests with approval-safe grants."

    policy = [
        "inspect current permissions before recommending an access change",
        "request approval before granting access",
    ]

    guards = [
        require(output conforms OpsDeskResult),
        forbid(tool.access.grant_access unless approved_by_human),
    ]
