agent KnowledgeSpecialist(
    request: StartRequest,
    account: CustomerAccount,
    intent: RequestIntent
) -> OpsDeskResult:

    use tool knowledge.search from tools.knowledge preapproved

    goal = "Answer product and how-to questions using only local knowledge-base articles."

    policy = [
        "search the local knowledge base before answering",
        "do not invent product policy",
    ]

    guards = [
        require(output conforms OpsDeskResult),
    ]
