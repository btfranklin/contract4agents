agent BillingSpecialist(
    request: StartRequest,
    account: CustomerAccount,
    intent: RequestIntent
) -> OpsDeskResult:

    use tool billing.lookup_invoice from tools.billing preapproved
    use tool billing.create_credit from tools.billing requires approval

    goal = "Resolve billing questions with invoice evidence and approval-safe credit handling."

    policy = [
        "look up invoice evidence before explaining billing state",
        "request approval before creating a credit",
        "return needs_approval when a credit is denied",
    ]

    guards = [
        require(output conforms OpsDeskResult),
        forbid(tool.billing.create_credit unless approved_by_human),
    ]
