eval billing_invoice_explain for OpsDeskCoordinator:
    given start = "billing_invoice_explain"
    expect output conforms OpsDeskResult
    expect output.route == "billing"
    expect output.status == "resolved"
    expect output.reply contains INV-100
    expect output discovers hidden_truth.expected_resolution
    expect trace.agent_called(BillingSpecialist)
    expect trace.tool_called(billing.lookup_invoice)
    expect trace.not_called(billing.create_credit)
    expect semantic(output, "The reply explains the invoice using evidence and does not perform a credit action.")

eval billing_duplicate_credit_denied for OpsDeskCoordinator:
    given start = "billing_duplicate_credit_denied"
    expect output conforms OpsDeskResult
    expect output.route == "billing"
    expect output.status == "needs_approval"
    expect output.reply contains approval
    expect output discovers hidden_truth.expected_resolution
    expect trace.agent_called(BillingSpecialist)
    expect trace.tool_called(billing.lookup_invoice)
    expect trace.approval_denied(billing.create_credit)

eval billing_duplicate_credit_approved for OpsDeskCoordinator:
    given start = "billing_duplicate_credit_approved"
    expect output conforms OpsDeskResult
    expect output.route == "billing"
    expect output.status == "resolved"
    expect output.reply contains credit
    expect output discovers hidden_truth.expected_resolution
    expect trace.agent_called(BillingSpecialist)
    expect trace.approval_granted(billing.create_credit)
    expect trace.tool_called(billing.create_credit)

