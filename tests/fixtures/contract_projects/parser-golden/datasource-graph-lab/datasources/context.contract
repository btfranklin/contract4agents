datasource AccountProfileSource:
    python = "tests.fixtures.parser_golden:account_profile"
    requires = [AccountSeed]
    produces = AccountProfile
    render = "markdown"
    cache = "none"

datasource BillingSnapshotSource:
    python = "tests.fixtures.parser_golden:billing_snapshot"
    requires = [AccountProfile]
    produces = BillingSnapshot
    render = "markdown"
    cache = "run"

datasource RiskSignalSource:
    python = "tests.fixtures.parser_golden:risk_signal"
    requires = [AccountProfile, BillingSnapshot]
    produces = RiskSignal
    render = "markdown"
    cache = "thread"

datasource RenderedContextSource:
    python = "tests.fixtures.parser_golden:rendered_context"
    requires = [AccountProfile, RiskSignal]
    produces = RenderedContext
    render = "markdown"
    cache = "run"
