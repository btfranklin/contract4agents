type AccountSeed:
    account_id: str
    region: str = "us"

type AccountProfile:
    account_id: str
    plan: str

type BillingSnapshot:
    balance: float
    invoice_count: int

type RiskSignal:
    risk_level: "low" | "medium" | "high"
    reason: str?

type RenderedContext:
    markdown: str

type GraphOutput:
    ok: bool
    summary: str
    action: str
