type ResearchPlan from python "tests.fixtures.pydantic_models:ResearchPlanModel"
type ResearchSummary from python "tests.fixtures.pydantic_models:ResearchSummaryModel"

agent ResearchPlanner(
    request: ResearchPlan
) -> ResearchSummary:

    goal = "Create a structured research summary from a Pydantic-backed plan."

    guards = [
        require(output conforms ResearchSummary),
    ]

    assertions = [
        expect(output conforms ResearchSummary),
    ]
