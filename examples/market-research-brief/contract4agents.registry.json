{
  "agents": {
    "CompetitorAnalyst": {
      "name": "CompetitorAnalyst"
    },
    "CurrentTruthScout": {
      "name": "CurrentTruthScout"
    },
    "CustomerSignalAnalyst": {
      "name": "CustomerSignalAnalyst"
    },
    "DocumentAnalyst": {
      "name": "DocumentAnalyst"
    },
    "MarketResearchLead": {
      "name": "MarketResearchLead"
    },
    "ReportWriter": {
      "name": "ReportWriter"
    }
  },
  "host_context": {
    "MarketResearchLead": [
      "DocumentEvidence",
      "CurrentFactEvidence",
      "CompetitorSnapshot",
      "CustomerSignalSummary"
    ]
  },
  "hosted_tools": {
    "openai.web_search": {
      "config": {
        "context_size": "medium"
      },
      "permissions": {
        "CurrentTruthScout": "available"
      },
      "provider": "openai",
      "tool": "web_search"
    }
  },
  "output_types": {},
  "prompts": {},
  "tools": {
    "citation.format": {
      "permissions": {
        "CompetitorAnalyst": "preapproved",
        "CurrentTruthScout": "preapproved",
        "CustomerSignalAnalyst": "preapproved",
        "DocumentAnalyst": "preapproved",
        "ReportWriter": "preapproved"
      },
      "python": "examples.market_research_brief_imports.citation:format"
    },
    "competitors.lookup": {
      "permissions": {
        "CompetitorAnalyst": "preapproved"
      },
      "python": "examples.market_research_brief_imports.competitors:lookup"
    },
    "current_facts.fetch": {
      "permissions": {
        "CurrentTruthScout": "preapproved"
      },
      "python": "examples.market_research_brief_imports.current_facts:fetch"
    },
    "current_facts.search": {
      "permissions": {
        "CurrentTruthScout": "preapproved"
      },
      "python": "examples.market_research_brief_imports.current_facts:search"
    },
    "documents.fetch": {
      "permissions": {
        "CustomerSignalAnalyst": "preapproved",
        "DocumentAnalyst": "preapproved"
      },
      "python": "examples.market_research_brief_imports.documents:fetch"
    },
    "documents.search": {
      "permissions": {
        "CustomerSignalAnalyst": "preapproved",
        "DocumentAnalyst": "preapproved"
      },
      "python": "examples.market_research_brief_imports.documents:search"
    }
  },
  "version": 2
}
