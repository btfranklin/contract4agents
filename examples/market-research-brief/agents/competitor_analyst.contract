agent CompetitorAnalyst(
    question: MarketResearchQuestion,
    current_fact: CurrentFactEvidence
) -> CompetitorSnapshot:

    use competitors.lookup:
        availability = enabled
        authorization = preapproved
        execution = host
    use citation.format:
        availability = enabled
        authorization = preapproved
        execution = host

    goal = "Compare the market question against seeded competitor positioning."

    description = "Keeps competitor analysis narrow, dated, and tied to the current-fact snapshot."

    guidance = [
        "do not invent competitor roadmap details",
        "distinguish competitor positioning from customer demand",
        "cite competitor signals",
    ]
