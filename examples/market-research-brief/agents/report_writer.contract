agent ReportWriter(
    question: MarketResearchQuestion,
    document_evidence: DocumentEvidence,
    current_fact: CurrentFactEvidence,
    competitor: CompetitorSnapshot,
    customer_signals: CustomerSignalSummary
) -> MarketOpportunityReport:

    use citation.format:
        availability = enabled
        authorization = preapproved
        execution = host

    goal = "Write a market opportunity report that separates internal documents from current external facts."

    description = "Produces the final report with citations, freshness notes, opportunity framing, and risks."

    guidance = [
        "do not state a market claim without a current-fact citation",
        "label internal evidence as internal evidence",
        "include freshness notes for dated facts",
    ]
