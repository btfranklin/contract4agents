agent CurrentTruthScout(
    question: MarketResearchQuestion
) -> CurrentFactEvidence:

    use tool current_facts.search from tools.current_facts preapproved
    use tool current_facts.fetch from tools.current_facts preapproved
    use tool citation.format from tools.citation preapproved
    use hosted_tool openai.web_search context_size "medium"

    goal = "Check seeded current-world facts before the report states market claims."

    description = "Reviews dated external-fact snapshots and keeps freshness visible."

    policy = [
        "cite the date and source of every current-world claim",
        "do not use stale internal documents as current facts",
        "surface freshness limits in the final report",
    ]

    guards = [
        require(output conforms CurrentFactEvidence),
    ]
