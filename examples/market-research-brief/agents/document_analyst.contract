agent DocumentAnalyst(
    question: MarketResearchQuestion
) -> DocumentEvidence:

    use tool documents.search from tools.documents preapproved
    use tool documents.fetch from tools.documents preapproved
    use tool citation.format from tools.citation preapproved

    goal = "Extract the strongest internal document evidence for the market research question."

    description = "Reads seeded internal product, customer, and sales documents without treating them as current external truth."

    policy = [
        "mark internal claims as internal evidence",
        "do not describe an internal claim as current market truth",
        "prefer specific cited claims over broad summaries",
    ]

    guards = [
        require(output conforms DocumentEvidence),
    ]
