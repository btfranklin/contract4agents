type MarketResearchQuestion:
    product_area: string
    target_segment: string
    decision: string
    as_of_date: string

type DocumentEvidence:
    document_id: string
    title: string
    claim: string
    citation: string

type CurrentFactEvidence:
    fact_id: string
    source: string
    as_of_date: string
    claim: string
    citation: string

type CompetitorSnapshot:
    competitor: string
    positioning: string
    recent_signal: string
    citation: string

type CustomerSignalSummary:
    pain_points: list[string]
    segments: list[string]
    citations: list[string]

type MarketOpportunityReport:
    thesis: string
    opportunity: string
    current_facts: list[string]
    internal_evidence: list[string]
    competitor_signals: list[string]
    customer_signals: list[string]
    risks: list[string]
    recommendation: string
    citations: list[string]
    freshness_notes: list[string]

type Citation:
    citation: string

type DocumentSearchHit:
    document_id: string
    title: string
    document_type: string
    snippet: string

type DocumentSearchResults:
    results: list[DocumentSearchHit]

type DocumentRecord:
    document_id: string
    title: string?
    document_type: string?
    body: string?
    created_at: string?
    found: boolean?

type CurrentFactSearchHit:
    fact_id: string
    source: string
    as_of_date: string
    snippet: string

type CurrentFactSearchResults:
    results: list[CurrentFactSearchHit]

type CurrentFactRecord:
    fact_id: string
    source: string?
    as_of_date: string?
    claim: string?
    found: boolean?

type CompetitorLookupResults:
    competitors: list[CompetitorSnapshot]

type WebSearchResult:
    title: string
    url: string
    snippet: string

type WebSearchResults:
    results: list[WebSearchResult]
