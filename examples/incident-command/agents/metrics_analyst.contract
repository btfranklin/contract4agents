agent MetricsAnalyst(
    request: IncidentReportRequest,
    service: ServiceCatalogEntry,
    window: TimeWindow
) -> MetricSnapshot:

    use metrics.query:
        availability = enabled
        authorization = preapproved
        execution = host

    goal = "Measure the incident impact using seeded metric data."

    description = "Queries latency and error-rate metrics for the incident service."

    guidance = [
        "use metric data only from the incident window",
        "summarize impact in operational terms",
    ]
