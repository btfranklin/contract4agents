agent IncidentCommander(
    request: IncidentReportRequest,
    service: ServiceCatalogEntry,
    window: TimeWindow
) -> IncidentBrief:

    use logs.search:
        availability = enabled
        authorization = approval_required
        execution = host

    use status_page.draft_update:
        availability = enabled
        authorization = approval_required
        execution = host

    context catalog_service: ServiceCatalogEntry from datasource incident.service:
        map service_id = input.service.id
    context active_incident: IncidentReportRequest from external active_incident

    goal = "Produce an evidence-backed incident brief for an active production incident."

    description = "Coordinates incident investigation and produces the final operational brief."

    guidance = [
        "prefer evidence over speculation",
        "cite log, deploy, or metric evidence before naming a likely cause",
        "do not publish a status-page draft without approval",
    ]
