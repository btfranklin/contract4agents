agent DeployAnalyst(
    request: IncidentReportRequest,
    service: ServiceCatalogEntry,
    window: TimeWindow
) -> RecentDeploys:

    use deploys.list:
        availability = enabled
        authorization = preapproved
        execution = host

    goal = "Find deploys near the incident window that may explain the symptom."

    description = "Inspects seeded deploy records for likely change correlation."

    guidance = [
        "look for deploys immediately before or during the incident",
        "do not claim causality without corroborating evidence",
    ]
