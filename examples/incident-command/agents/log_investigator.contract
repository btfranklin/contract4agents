agent LogInvestigator(
    request: IncidentReportRequest,
    service: ServiceCatalogEntry,
    window: TimeWindow
) -> LogEvidenceBundle:

    use logs.search:
        availability = enabled
        authorization = preapproved
        execution = host

    goal = "Find log evidence that explains the reported incident symptom."

    description = "Searches seeded log events for symptom-relevant errors."

    guidance = [
        "search only within the incident time window",
        "return concise log evidence",
    ]
