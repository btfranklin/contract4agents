type IncidentReportRequest:
    service: string
    start: datetime
    end: datetime
    symptom: string

type ServiceCatalogEntry:
    id: string
    name: string
    owner: string

type TimeWindow:
    start: datetime
    end: datetime

type LogEvidenceBundle:
    events: list[string]

type RecentDeploys:
    deploys: list[string]

type MetricSnapshot:
    metric: string
    max_value: float
    summary: string

type IncidentBrief:
    summary: string
    likely_cause: string
    evidence: list[string]
    next_actions: list[string]

type StatusPageDraft:
    draft_id: integer
    incident_id: string
    message: string
