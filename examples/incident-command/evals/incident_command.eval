eval discovers_checkout_cause for IncidentCommander:
    given start = "discovers_checkout_cause"
    given request = IncidentReportRequest.fixture("checkout_latency")
    given service = ServiceCatalogEntry.fixture("checkout-api")
    given window = TimeWindow.fixture("incident_window")

    expect output conforms IncidentBrief
    expect output discovers hidden_truth.likely_cause
    expect trace.tool_called(logs.search)
    expect trace.tool_called(deploys.list)
    expect trace.tool_called(metrics.query)
    expect trace.agent_called(LogInvestigator)
    expect trace.agent_called(DeployAnalyst)
    expect trace.agent_called(MetricsAnalyst)
    expect trace.not_called(status_page.draft_update)
    expect quality(concise_operational_summary)
