type ResearchQuestion:
    topic: string
    decision: string
    audience: string
    risk_tolerance: string

type SourceEvidence:
    source_id: string
    title: string
    lens: string
    claim: string
    citation: string

type EvidenceMap:
    topic: string
    source_ids: list[string]
    claims: list[string]
    citations: list[string]
    quality_notes: list[string]

type TechnicalAssessment:
    feasibility: string
    implementation_risks: list[string]
    required_controls: list[string]
    citations: list[string]

type PolicySafetyAssessment:
    policy_risks: list[string]
    safety_risks: list[string]
    mitigation_requirements: list[string]
    citations: list[string]

type CounterargumentSet:
    strongest_counterarguments: list[string]
    weak_assumptions: list[string]
    disconfirming_sources: list[string]
    citations: list[string]

type ResearchBrief:
    summary: string
    recommendation: string
    confidence: float
    key_findings: list[string]
    risks: list[string]
    counterarguments: list[string]
    citations: list[string]
    next_actions: list[string]

type SourceSearchResults:
    results: list[string]

type SourceRecord:
    source_id: string
    found: boolean?
    title: string?
    lens: string?
    body: string?
    quality: float?

type EvidenceScore:
    source_id: string
    score: float
    rationale: string

type FormattedCitation:
    citation: string

type ExpertReviewRequest:
    topic: string
    summary: string
    requested: boolean
