agent ResearchDirector(
    question: ResearchQuestion
) -> ResearchBrief:

    use expert_review.request:
        availability = enabled
        authorization = approval_required
        execution = host

    goal = "Coordinate a multi-lens research brief for a high-stakes decision."

    description = "Keeps the research process split into focused specialist lenses before writing a final recommendation."

    guidance = [
        "delegate source mapping before synthesis",
        "keep technical and policy-safety judgments separate",
        "include counterarguments before making a recommendation",
        "do not request external expert review without human approval",
    ]
