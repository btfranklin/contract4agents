agent TechnicalLensAnalyst(
    question: ResearchQuestion,
    evidence: EvidenceMap
) -> TechnicalAssessment:

    use tool sources.fetch from tools.sources preapproved
    use tool evidence.score from tools.evidence preapproved

    goal = "Evaluate technical feasibility and implementation risk for the research decision."

    description = "Reviews technical evidence only, keeping implementation judgment narrow and source-backed."

    policy = [
        "stay focused on technical feasibility",
        "name implementation risks separately from policy risks",
        "cite evidence before recommending controls",
    ]

    guards = [
        require(output conforms TechnicalAssessment),
    ]
